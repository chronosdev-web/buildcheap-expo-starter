// Environment configuration
// Copy this file to .env and fill in your values

// Server
PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-this

// Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

// Build Infrastructure
# Linux server for Android builds (localhost or remote)
ANDROID_BUILD_HOST=localhost

# macOS server for iOS builds (Hetzner Mac Mini or similar)
IOS_BUILD_HOST=
IOS_BUILD_USER=
IOS_BUILD_SSH_KEY=

# Build artifacts storage directory
ARTIFACTS_DIR=./artifacts

# Minimum credit purchase in dollars
MIN_CREDIT_PURCHASE=5
COST_PER_BUILD=0.50
